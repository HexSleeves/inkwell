# Copy this file to .env for local development. The .env file is gitignored.
DATABASE_URL=postgres://inkwell:replace-with-postgres-password@localhost:5432/inkwell
PORT=3000
HOST=0.0.0.0

# Leave blank until you set a real key. Replace it before any shared or exposed deployment.
INKWELL_API_KEY=

# Separate credential the `inkwell mcp` server uses to authenticate against the
# write API, so AI/MCP access can be granted and revoked independently of the
# human authoring key. Leave blank to disable the MCP walkthrough; set a real
# value to let an AI agent read/search/edit the garden (see docs/QUICKSTART.md).
INKWELL_MCP_KEY=

INKWELL_SITE_URL=http://localhost:3000

# Base URL the `inkwell author` CLI targets. Defaults to http://HOST:PORT.
INKWELL_API_URL=http://localhost:3000

POSTGRES_USER=inkwell
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=inkwell
POSTGRES_PORT=5432
