# Copy this file to .env for local development. The .env file is gitignored.
DATABASE_URL=postgres://inkwell:inkwell@localhost:5433/inkwell
PORT=3000
HOST=0.0.0.0

# Leave blank until you set a real key. Replace it before any shared or exposed deployment.
INKWELL_API_KEY=

# Separate credential the `inkwell mcp` server uses to authenticate against the
# write API, so AI/MCP access can be granted and revoked independently of the
# human authoring key. Leave blank to disable the MCP walkthrough; set a real
# value to let an AI agent read/search/edit the garden (see docs/QUICKSTART.md).
INKWELL_MCP_KEY=

INKWELL_SITE_URL=http://localhost:3000

# Base URL the `inkwell author` CLI targets. Defaults to http://HOST:PORT.
INKWELL_API_URL=http://localhost:3000

# --- AI / semantic layer (card T10) -----------------------------------------
# All optional. With both keys blank the site still works: full-text search runs
# (no keys needed), note embeddings are generated by a deterministic mock so
# related-notes still works, and `/ask` returns a clear "AI features not
# configured" response instead of erroring. Set the keys to enable real
# providers. NEVER commit real key values.

# Voyage AI key for note embeddings (semantic / related-notes). Leave blank to
# fall back to the deterministic mock embedder.
VOYAGE_API_KEY=

# Anthropic (Claude) key for ask-your-garden answer synthesis. Leave blank to
# disable AI answers (the /ask endpoint reports "AI features not configured").
ANTHROPIC_API_KEY=

# Claude model used for /ask synthesis. Defaults to claude-opus-4-8.
INKWELL_LLM_MODEL=claude-opus-4-8

POSTGRES_USER=inkwell
POSTGRES_PASSWORD=inkwell
POSTGRES_DB=inkwell
POSTGRES_PORT=5433
