# Copy this file to .env for local development. The .env file is gitignored.
PORT=3000
HOST=0.0.0.0

POSTGRES_USER=inkwell
POSTGRES_PASSWORD=inkwell
POSTGRES_DB=inkwell
POSTGRES_PORT=5433
DATABASE_URL=postgres://inkwell:inkwell@localhost:5433/inkwell

# Leave blank until you set a real key. Replace it before any shared or exposed deployment.
INKWELL_API_KEY=

# MCP / AI-agent access: the `inkwell mcp` server reads INKWELL_API_KEY from ITS
# environment. Set that to a SCOPED TOKEN (mint one with
# `inkwell author token create --name agent --scopes read,write`) so MCP access
# is grant/revocable independently of the admin key. The old INKWELL_MCP_KEY was
# retired in slice 4 — see docs/QUICKSTART.md and the MCP config (.mcp.json).

INKWELL_SITE_URL=http://localhost:3000

# --- Site metadata and branding (CIL-131) ------------------------------------
# Human-readable site title used in the HTML header, feed title, and page
# <title> suffix. Defaults to "Inkwell" when unset.
INKWELL_SITE_TITLE=Inkwell

# Optional site-level description. When set, used as the index page meta
# description and the Atom feed subtitle. Omitted from HTML when blank.
INKWELL_SITE_DESCRIPTION=

# Optional default author name. When set, added to JSON-LD BlogPosting
# "author" and the Atom feed <author> element. Omitted when blank.
INKWELL_SITE_AUTHOR=

# Optional URL of a custom stylesheet loaded on every public HTML page via
# <link rel="stylesheet">. Use to apply a custom theme without touching
# source code. Omitted when blank.
INKWELL_CUSTOM_CSS_URL=

# Base URL the `inkwell author` CLI targets. Defaults to http://HOST:PORT.
INKWELL_API_URL=http://localhost:3000

# --- Write rate limiting (CIL-128) ------------------------------------------
# Pragmatic abuse guard on mutation routes (create/update/delete/publish/
# unpublish, POST /media, /webmention) and the expensive /ask endpoint, in
# requests per minute. Bucketed per VALIDATED principal (the credential is
# verified before it keys a bucket, so random keys can't mint quotas), else per
# client IP. Read paths and the public HTML site are NEVER throttled. Over-limit
# requests get 429 with a Retry-After header. Set to 0 to disable. Default: 60.
INKWELL_WRITE_RATE_LIMIT=60

# Trust X-Forwarded-For / X-Real-IP when keying the limiter by client IP. Those
# headers are client-spoofable, so this is OFF by default and IP keying uses the
# real peer address. Set to true ONLY behind a proxy that overwrites them (e.g.
# Railway) to get per-client IP buckets instead of one shared bucket. Default: false.
INKWELL_TRUST_FORWARDED_HEADERS=false

# --- AI / semantic layer (card T10) -----------------------------------------
# All optional. With both keys blank the site still works: full-text search runs
# (no keys needed), note embeddings are generated by a deterministic mock so
# related-notes still works, and `/ask` returns a clear "AI features not
# configured" response instead of erroring. Set the keys to enable real
# providers. NEVER commit real key values.

# Voyage AI key for note embeddings (semantic / related-notes). Leave blank to
# fall back to the deterministic mock embedder.
VOYAGE_API_KEY=

# Anthropic (Claude) key for ask-your-garden answer synthesis. Leave blank to
# disable AI answers (the /ask endpoint reports "AI features not configured").
ANTHROPIC_API_KEY=

# Claude model used for /ask synthesis. Defaults to claude-sonnet-4-6.
INKWELL_LLM_MODEL=claude-sonnet-4-6

# --- Federation / Webmention (card T11) -------------------------------------
# Receiving Webmentions (POST /webmention) is always on. SENDING a Webmention
# when a published note links out is OPT-IN and defaults to OFF: with this unset
# (or anything other than "true") the send path is fully inert — no outbound
# requests are made on publish. Set to "true" only if you want this site to
# notify the external pages your notes link to. Every outbound fetch (both
# verification of received mentions and sending) is SSRF-hardened: http(s) only,
# private/loopback/link-local/cloud-metadata ranges are refused, redirects are
# re-validated, and body size + timeout are capped.
INKWELL_WEBMENTION_SEND=false
